{
  "name": "stlaf-aoi-generator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx api/index.ts",
    "build": "vite build && esbuild api/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "preview": "vite preview",
    "start": "node dist/server.cjs",
    "lint": "echo 'No lint script configured'"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "express": "^4.22.1",
    "groq-sdk": "^1.1.2",
    "lucide-react": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.17",
    "@types/pdf-parse": "^1.1.5",
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.1.0"
  }
}
